{
  "name": "@samgalanakis/cupel",
  "version": "0.6.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Make your clanker your investing analyst. A personal research companion that learns your edges and stress-tests your ideas against the investing canon.",
  "license": "MIT",
  "author": "Samuel Galanakis",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SamGalanakis/cupel.git"
  },
  "homepage": "https://github.com/SamGalanakis/cupel",
  "keywords": [
    "investing",
    "stocks",
    "research",
    "skills",
    "peter-lynch",
    "value-investing",
    "portfolio",
    "ai"
  ],
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "cupel": "cli/dist/index.js"
  },
  "main": "engine/dist/index.js",
  "exports": {
    ".": "./engine/dist/index.js"
  },
  "files": [
    "cli/dist",
    "engine/dist",
    "skills",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build:engine": "tsc -p engine",
    "build:cli": "tsc -p cli",
    "build": "npm run build:engine && npm run build:cli",
    "build:cowork": "node scripts/build-cowork-zip.mjs",
    "sync:skills": "node scripts/sync-skill-copies.mjs",
    "test": "vitest run",
    "prepack": "npm run build",
    "release": "node scripts/release.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
